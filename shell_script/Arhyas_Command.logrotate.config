"/Applications/Arhyas Command Multilingual for MacOS 11+.app/Contents/Resources/log/error.log"
{
	size 20M
	rotate 12
	compress
	delaycompress
	missingok
	notifempty
	copytruncate
}


"/Applications/Arhyas Command Multilingual for MacOS 11+.app/Contents/Resources/log/arhyas_command.log"
{
	size 20M
	rotate 12
	compress
	delaycompress
	missingok
	notifempty
	copytruncate
}

"~/Arhyas_Command/log/error.log"
{
	size 20M
	rotate 12
	compress
	delaycompress
	missingok
	notifempty
	copytruncate
}


"~/Arhyas_Command/log/arhyas_command.log"
{
	size 20M
	rotate 12
	compress
	delaycompress
	missingok
	notifempty
	copytruncate
}